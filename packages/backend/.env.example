# overseer backend environment variables

PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Groq (primary key + optional rotation keys for higher throughput)
GROQ_API_KEY=your_groq_api_key_here
# GROQ_API_KEY_1=second_key_for_rotation
# GROQ_API_KEY_2=third_key_for_rotation

# JWT — generate a strong random string for production
JWT_SECRET=change_this_to_a_long_random_string

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000
